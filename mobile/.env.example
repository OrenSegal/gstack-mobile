# App Store Connect (iOS ship + TestFlight)
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_PRIVATE_KEY_PATH=~/.appstore/AuthKey_XXXXXXXX.p8

# Google Play (Android ship)
PLAY_SERVICE_ACCOUNT_JSON=~/.google/play-service-account.json

# Crash reporting
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Firebase (Crashlytics + Performance)
FIREBASE_TOKEN=
FIREBASE_PROJECT_ID=

# Expo (if using EAS)
EXPO_TOKEN=

# Analytics (events verification in /analytics-audit)
AMPLITUDE_API_KEY=
MIXPANEL_PROJECT_TOKEN=